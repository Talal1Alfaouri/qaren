# ========================
# QAREN - Environment Config
# ========================
# Copy this to .env and fill in values

# Database
DB_USER=qaren
DB_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql://qaren:your-secure-password-here@localhost:5432/qaren

# Redis
REDIS_URL=redis://localhost:6379

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-min-32-chars-here

# Affiliate Programs
AMAZON_AFFILIATE_TAG=qaren-21          # Get from Amazon Associates SA
NOON_AFFILIATE_ID=                     # Get from Noon Partners program
JARIR_AFFILIATE_ID=                    # If available

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Qaren

# Analytics (optional)
NEXT_PUBLIC_GA_ID=                     # Google Analytics 4

# Scraping
SCRAPE_INTERVAL_HOURS=4
SCRAPER_CONCURRENCY=3
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; QarenBot/1.0; +https://qaren.sa/bot)

# AI Matching (optional - for embedding similarity)
OPENAI_API_KEY=                        # For text embeddings (optional)

# Admin
ADMIN_EMAIL=admin@qaren.sa
ADMIN_PASSWORD=change-me-immediately
